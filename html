<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gold Premier Analytics</title>
    <script src="[cdn.jsdelivr.net](https://cdn.jsdelivr.net/npm/chart.js)"></script>
    <script src="[cdn.tailwindcss.com](https://cdn.tailwindcss.com)"></script>
    <link href="[fonts.googleapis.com](https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap)" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .gold-gradient { background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%); }
        .card { backdrop-filter: blur(10px); }
        .glow { box-shadow: 0 0 30px rgba(255, 215, 0, 0.3); }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
        .loading { animation: pulse 1.5s infinite; }
    </style>
</head>
<body class="bg-gray-900 text-white min-h-screen">
    <!-- Header -->
    <header class="gold-gradient py-6 px-4 shadow-lg">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <div class="flex items-center space-x-3">
                <span class="text-4xl">🥇</span>
                <div>
                    <h1 class="text-2xl md:text-3xl font-bold text-gray-900">GOLD PREMIER ANALYTICS</h1>
                    <p class="text-gray-800 text-sm">Real-time Price Analysis & Forecasting</p>
                </div>
            </div>
            <button onclick="refreshData()" class="bg-gray-900 text-white px-4 py-2 rounded-lg hover:bg-gray-800 transition flex items-center space-x-2">
                <span id="refresh-icon">🔄</span>
                <span>Refresh</span>
            </button>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 py-8">
        <!-- Metrics Grid -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
            <div class="card bg-gray-800 rounded-xl p-6 border-l-4 border-yellow-500 glow">
                <p class="text-gray-400 text-sm mb-1">💰 Price per Gram</p>
                <p id="price-gram" class="text-3xl font-bold text-yellow-400 loading">₹--</p>
                <p id="price-change" class="text-sm mt-2">--</p>
            </div>
            <div class="card bg-gray-800 rounded-xl p-6 border-l-4 border-blue-500">
                <p class="text-gray-400 text-sm mb-1">📦 Price per 10g</p>
                <p id="price-10g" class="text-3xl font-bold text-blue-400 loading">₹--</p>
            </div>
            <div class="card bg-gray-800 rounded-xl p-6 border-l-4 border-green-500">
                <p class="text-gray-400 text-sm mb-1">💵 Gold (USD/oz)</p>
                <p id="price-usd" class="text-3xl font-bold text-green-400 loading">$--</p>
            </div>
            <div class="card bg-gray-800 rounded-xl p-6 border-l-4 border-purple-500">
                <p class="text-gray-400 text-sm mb-1">💱 USD/INR</p>
                <p id="usdinr" class="text-3xl font-bold text-purple-400 loading">₹--</p>
            </div>
        </div>

        <!-- Charts Section -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
            <div class="lg:col-span-2 card bg-gray-800 rounded-xl p-6">
                <h2 class="text-xl font-semibold mb-4">📈 Price Trajectory & Forecast</h2>
                <canvas id="priceChart" height="300"></canvas>
            </div>
            <div class="card bg-gray-800 rounded-xl p-6">
                <h2 class="text-xl font-semibold mb-4">📊 Statistics</h2>
                <div class="space-y-4">
                    <div class="flex justify-between items-center p-3 bg-gray-700 rounded-lg">
                        <span class="text-gray-400">Mean Price</span>
                        <span id="stat-mean" class="font-semibold text-yellow-400">--</span>
                    </div>
                    <div class="flex justify-between items-center p-3 bg-gray-700 rounded-lg">
                        <span class="text-gray-400">Std Deviation</span>
                        <span id="stat-std" class="font-semibold">--</span>
                    </div>
                    <div class="flex justify-between items-center p-3 bg-gray-700 rounded-lg">
                        <span class="text-gray-400">52-Week Low</span>
                        <span id="stat-min" class="font-semibold text-red-400">--</span>
                    </div>
                    <div class="flex justify-between items-center p-3 bg-gray-700 rounded-lg">
                        <span class="text-gray-400">52-Week High</span>
                        <span id="stat-max" class="font-semibold text-green-400">--</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Forecast Table -->
        <div class="card bg-gray-800 rounded-xl p-6">
            <h2 class="text-xl font-semibold mb-4">📅 12-Month Bullish Forecast</h2>
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-gray-700">
                            <th class="text-left py-3 px-4 text-gray-400">Month</th>
                            <th class="text-right py-3 px-4 text-gray-400">Predicted Price (₹/gram)</th>
                        </tr>
                    </thead>
                    <tbody id="forecast-table">
                        <tr><td colspan="2" class="py-4 text-center text-gray-500">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="text-center py-6 text-gray-500 text-sm">
        <p>Last updated: <span id="last-updated">--</span> | Data source: Yahoo Finance</p>
        <p class="mt-1">Tax calculation: 6% Import Duty + 3% GST = 9.2% Total</p>
    </footer>

    <script>
        let priceChart = null;

        async function fetchData() {
            try {
                const response = await fetch('/api/data');
                const data = await response.json();
                
                if (data.success) {
                    updateUI(data);
                } else {
                    console.error('Error:', data.error);
                }
            } catch (error) {
                console.error('Fetch error:', error);
            }
        }

        function updateUI(data) {
            // Update metrics
            document.getElementById('price-gram').textContent = `₹${data.current.price_gram.toLocaleString()}`;
            document.getElementById('price-gram').classList.remove('loading');
            
            document.getElementById('price-10g').textContent = `₹${(data.current.price_gram * 10).toLocaleString()}`;
            document.getElementById('price-10g').classList.remove('loading');
            
            document.getElementById('price-usd').textContent = `$${data.current.price_usd.toLocaleString()}`;
            document.getElementById('price-usd').classList.remove('loading');
            
            document.getElementById('usdinr').textContent = `₹${data.current.usdinr}`;
            document.getElementById('usdinr').classList.remove('loading');

            const changeEl = document.getElementById('price-change');
            const changeClass = data.current.change >= 0 ? 'text-green-400' : 'text-red-400';
            const arrow = data.current.change >= 0 ? '▲' : '▼';
            changeEl.className = `text-sm mt-2 ${changeClass}`;
            changeEl.textContent = `${arrow} ₹${Math.abs(data.current.change)} (${data.current.change_pct}%)`;

            // Update statistics
            document.getElementById('stat-mean').textContent = `₹${data.statistics.mean.toLocaleString()}`;
            document.getElementById('stat-std').textContent = `₹${data.statistics.std.toLocaleString()}`;
            document.getElementById('stat-min').textContent = `₹${data.statistics.min.toLocaleString()}`;
            document.getElementById('stat-max').textContent = `₹${data.statistics.max.toLocaleString()}`;

            // Update chart
            updateChart(data);

            // Update forecast table
            const tableBody = document.getElementById('forecast-table');
            tableBody.innerHTML = data.forecast.months.map((month, i) => `
                <tr class="border-b border-gray-700 hover:bg-gray-700 transition">
                    <td class="py-3 px-4">${month}</td>
                    <td class="py-3 px-4 text-right font-semibold text-yellow-400">₹${data.forecast.predictions[i].toLocaleString()}</td>
                </tr>
            `).join('');

            // Update timestamp
            document.getElementById('last-updated').textContent = data.updated;
        }

        function updateChart(data) {
            const ctx = document.getElementById('priceChart').getContext('2d');
            
            if (priceChart) {
                priceChart.destroy();
            }

            const allLabels = [...data.historical.dates.slice(-60), ...data.forecast.months];
            const historicalData = [...data.historical.prices.slice(-60), ...Array(data.forecast.months.length).fill(null)];
            const forecastData = [...Array(60).fill(null), ...data.forecast.predictions];

            priceChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: allLabels,
                    datasets: [
                        {
                            label: 'Historical Price',
                            data: historicalData,
                            borderColor: '#3498db',
                            backgroundColor: 'rgba(52, 152, 219, 0.1)',
                            fill: true,
                            tension: 0.4,
                            pointRadius: 0
                        },
                        {
                            label: 'Bullish Forecast',
                            data: forecastData,
                            borderColor: '#F67E22',
                            backgroundColor: 'rgba(246, 126, 34, 0.1)',
                            fill: true,
                            tension: 0.4,
                            borderDash: [5, 5],
                            pointRadius: 4,
                            pointBackgroundColor: '#F67E22'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            labels: { color: '#fff' }
                        }
                    },
                    scales: {
                        x: {
                            ticks: { color: '#888', maxTicksLimit: 10 },
                            grid: { color: 'rgba(255,255,255,0.1)' }
                        },
                        y: {
                            ticks: { 
                                color: '#888',
                                callback: value => '₹' + value.toLocaleString()
                            },
                            grid: { color: 'rgba(255,255,255,0.1)' }
                        }
                    }
                }
            });
        }

        function refreshData() {
            const icon = document.getElementById('refresh-icon');
            icon.style.animation = 'spin 1s linear infinite';
            
            fetchData().then(() => {
                setTimeout(() => {
                    icon.style.animation = '';
                }, 1000);
            });
        }

        // Initial load
        fetchData();

        // Auto-refresh every 5 minutes
        setInterval(fetchData, 300000);
    </script>
</body>
</html>
